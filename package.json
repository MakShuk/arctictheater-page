    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
